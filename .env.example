# Shopify Admin API
SHOPIFY_STORE_NAME=your-store-name
SHOPIFY_ACCESS_TOKEN=shpat_xxxxxxxxxxxxx

# ShipBob (EU warehouse) — https://developer.shipbob.com/
EU_WAREHOUSE_URL=https://api.shipbob.com/2.0/order
EU_WAREHOUSE_API_KEY=your-shipbob-pat-token
SHIPBOB_CHANNEL_ID=12345

# DCL Logistics (US warehouse) — https://api.dclcorp.com/Help
US_WAREHOUSE_URL=https://api.dclcorp.com/api/v1/batches
DCL_USERNAME=your-dcl-username
DCL_PASSWORD=your-dcl-password
DCL_ACCOUNT_NUMBER=your-dcl-account-number

# Set to "true" to actually POST to warehouse endpoints (default: log only)
LIVE_MODE=false
